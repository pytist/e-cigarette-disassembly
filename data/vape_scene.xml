<mujoco model="vape_disassembly">
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <asset>
    <texture type="2d" name="grid" builtin="checker" width="512" height="512" rgb1="0.8 0.8 0.8" rgb2="0.6 0.6 0.6"/>
    <material name="grid_mat" texture="grid" texrepeat="5 5"/>
    <mesh name="outer_shell" file="cad_files/Outer shell.obj" scale="0.01 0.01 0.01"/>
    <mesh name="mouthpiece" file="cad_files/Mouthpiece.obj" scale="0.01 0.01 0.01"/>
    <mesh name="bottom_cap" file="cad_files/Bottom cap.obj" scale="0.01 0.01 0.01"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="1 1 1"/>
    <geom type="plane" size="1 1 0.01" material="grid_mat"/>

    <!-- Vape body (fixed in a fixture on the table) -->
    <body name="vape_fixture" pos="0.5 0 0.15">
      <!-- Outer shell - fixed -->
      <geom type="mesh" mesh="outer_shell" rgba="0.5 0.5 0.5 1"/>
      <!-- Mouthpiece - fixed to the shell -->
      <geom type="mesh" mesh="mouthpiece" rgba="0.3 0.3 0.3 1"/>

      <!-- Bottom cap (the pin to pull out) - slides along Z axis -->
      <body name="bottom_cap" pos="0 0 0">
        <joint name="pin_slide" type="slide" axis="0 0 -1" range="0 0.05" damping="5"/>
        <geom type="mesh" mesh="bottom_cap" rgba="0.7 0.7 0.7 1"/>
      </body>
    </body>
  </worldbody>
</mujoco>
